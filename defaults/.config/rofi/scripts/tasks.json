[
  {
    "name": "📦 arch update",
    "command": "$TERMINAL arch-upkeep.sh"
  },
  {
    "name": "🔒 network-wireguard-home-start",
    "command": "sudo systemctl start wg-quick@home"
  },
  {
    "name": "🔓 network-wireguard-home-stop",
    "command": "sudo systemctl stop wg-quick@home"
  },
  {
    "name": "☀️ flux force day",
    "command": "exec $HOME/.config/redshift/hooks/neoflux period-changed 88 daytime >>/tmp/flux.log 2>&1"
  },
  {
    "name": "🌑 flux force night",
    "command": "exec $HOME/.config/redshift/hooks/neoflux period-changed 88 night >>/tmp/flux.log 2>&1"
  },
  {
    "name": "📷 qrencode clipboard",
    "command": "wl-paste | qrencode -o - | swayimg -"
  },
  {
    "name": "📷 qrencode x11 clipboard",
    "command": "xclip -selection clipboard -o | qrencode -o - |  feh -FZ -"
  },
  {
    "name": "🎧 bluetooth wh-1000xm4",
    "command": "exec $HOME/.config/i3/scripts/bluetooth.lua 'connect' '14:3F:A6:EA:F5:D1'"
  },
  {
    "name": "🎧 bluetooth wh-1000xm2",
    "command": "exec $HOME/.config/i3/scripts/bluetooth.lua 'connect' '04:5D:4B:EA:9C:B2'"
  },
  {
    "name": "🎧 bluetooth philips pn402",
    "command": "exec $HOME/.config/i3/scripts/bluetooth.lua 'connect' '88:D0:39:48:7D:00'"
  },
  {
    "name": "📴 bluetooth disconnect",
    "command": "exec $HOME/.config/i3/scripts/bluetooth.lua 'disconnect'"
  },
  {
    "name": "🚲 bike activities strava plot progress",
    "command": "rm /tmp/bike.{csv,html}; strava-activities -d 10 $HOME/.local/bin/strava.ini; $BROWSER /tmp/bike.html"
  },
  {
    "name": "🏖️ clearwater weather radar",
    "command": "$BROWSER https://www.accuweather.com/en/us/clearwater/33755/weather-radar/332295"
  },
  {
    "name": "🏖️ clearwater beach camera",
    "command": "$BROWSER https://www.visitstpeteclearwater.com/webcams"
  },
  {
    "name": "🖥️ power off",
    "command": "systemctl poweroff"
  },
  {
    "name": "💻 power reboot/restart",
    "command": "systemctl reboot"
  },
  {
    "name": "🔐 power lock",
    "command": "dm-tool switch-to-greeter"
  },
  {
    "name": "🔑 pass root",
    "command": "pass --clip linux/`hostname`/user/root"
  },
  {
    "name": "🔑 pass ssh key github",
    "command": "pass --clip linux/`hostname`/ssh_key/id_ed25519_github"
  },
  {
    "name": "📂 whatsapp text",
    "command": "exec $BROWSER https://web.whatsapp.com"
  },
  {
    "name": "🖼️ wallpaper random",
    "command": "exec arch-random-wallpaper"
  },
  {
    "name": "🌃 redshift toggle night",
    "command": "exec ~/.config/polybar/scripts/redshift-toggle.sh"
  },
  {
    "name": "📷 text snatcher ocr image",
    "command": "exec $HOME/.config/polybar/scripts/text-snatcher-native.sh"
  },
  {
    "name": "⌨️ fix default application to open url links obsidian firefox",
    "command": "exec xdg-mime default firefox.desktop x-scheme-handler/https x-scheme-handler/http"
  },
  {
    "name": "🗓️ calendar popup",
    "command": "galendae"
  },
  {
    "name": "✈️ airplane mode on",
    "command": "rfkill block all; echo '✈️' > /tmp/airplane_mode; systemctl --user stop rslsync"
  },
  {
    "name": "✈️ airplane mode off",
    "command": "rfkill unblock all; echo '' > /tmp/airplane_mode; systemctl --user stop rslsync"
  },
  {
    "name": "✈️ sway workspace organize fix monitors",
    "command": "exec sway-organize-workspaces.sh > /tmp/organize-workspaces.log"
  }
]
